      "description": "Multiple Windows persistence mechanisms installed",
      "mitreTactic": "Persistence"
    },
    {
      "id": "SEQ-013",
      "enabled": true,
      "name": "Linux SUID Exploitation",
      "patterns": ["find.*-perm.*4000", "getcap\\s+-r", "\\.\\/.+\\s+"],
