  "sequences": [
    {
      "id": "SEQ-001",
      "enabled": true,
      "name": "Credential Harvesting Chain",
      "patterns": ["whoami|id\\b", "cat.*passwd|net\\s+user", "cat.*shadow|hashdump"],
      "risk": "critical",
      "description": "Sequential enumeration leading to credential access",
      "mitreTactic": "Credential Access"
    },
    {
      "id": "SEQ-002",
      "enabled": true,
      "name": "Privilege Escalation Chain",
      "patterns": ["sudo\\s+-l|find.*-perm.*4000", "sudo\\s+", "id.*root|whoami.*root"],
      "risk": "critical",
      "description": "Privilege check followed by escalation attempt",
      "mitreTactic": "Privilege Escalation"
    },
    {
      "id": "SEQ-003",
      "enabled": true,
      "name": "Reconnaissance to Exfiltration",
      "patterns": ["ls|find|dir", "tar\\s+|zip\\s+", "scp|curl.*-F|rsync"],
      "risk": "high",
      "description": "File enumeration followed by archiving and transfer",
      "mitreTactic": "Exfiltration"
    },
    {
      "id": "SEQ-004",
      "enabled": true,
      "name": "Defense Evasion Chain",
      "patterns": ["history\\s+-c|rm.*history", "unset\\s+HISTFILE", "rm.*\\.log|shred"],
      "risk": "high",
      "description": "Multiple track-covering activities detected",
      "mitreTactic": "Defense Evasion"
    },
    {
      "id": "SEQ-005",
      "enabled": true,
      "name": "Lateral Movement Preparation",
      "patterns": ["ssh-keygen|cat.*id_rsa", "ssh\\s+\\S+@", "scp.*@.*:"],
      "risk": "high",
      "description": "SSH key operations followed by remote access",
      "mitreTactic": "Lateral Movement"
    },
    {
      "id": "SEQ-006",
      "enabled": true,
      "name": "Persistence Installation",
      "patterns": ["useradd|net\\s+user.*\\/add", "echo.*>>.*authorized_keys|crontab", "systemctl\\s+enable"],
      "risk": "critical",
      "description": "User creation followed by persistence mechanism",
      "mitreTactic": "Persistence"
    },
    {
      "id": "SEQ-007",
      "enabled": true,
      "name": "Data Collection Chain",
      "patterns": ["find.*-name|dir\\s+\\/s", "mysqldump|pg_dump|tar", "base64|gzip"],
