      "risk": "critical",
      "description": "Container environment detection followed by escape attempt",
      "mitreTactic": "Privilege Escalation"
    },
    {
      "id": "SEQ-009",
      "enabled": true,
      "name": "Windows LOLBin Attack Chain",
      "patterns": ["certutil.*-urlcache|bitsadmin.*\\/transfer", "rundll32|regsvr32|mshta", "cmd|powershell.*-e"],
