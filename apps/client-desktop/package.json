{
  "name": "@smartaiaudit/client-desktop",
  "version": "1.0.0",
  "description": "SmartAudit Client Desktop Application",
  "main": "./dist-electron/main/index.js",
  "homepage": "https://github.com/zenosaika/SmartAIAudit",
  "author": {
    "name": "SmartAudit",
    "email": "smartaudit@users.noreply.github.com"
  },
  "license": "PROPRIETARY",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.{ts,tsx}",
    "package": "electron-builder",
    "package:mac": "electron-builder --mac",
    "package:win": "electron-builder --win --x64"
  },
  "dependencies": {
    "@smartaiaudit/shared": "workspace:*",
    "@supabase/supabase-js": "^2.39.0",
    "@electron-toolkit/utils": "^3.0.0",
    "electron-updater": "^6.1.7",
    "guacamole-common-js": "^1.3.0",
    "zustand": "^4.4.7",
    "socket.io-client": "^4.6.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.0.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "tailwindcss": "^3.4.0",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32"
  },
  "build": {
    "appId": "com.smartaudit.client",
    "productName": "SmartAudit Client",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "dist/**/*"
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage"
      ],
      "category": "Utility",
      "artifactName": "smartaudit-client_${version}_${arch}.${ext}"
    }
  }
}
