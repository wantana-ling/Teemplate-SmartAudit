# ============================================================================
# SmartAIAudit — Deployment Environment Variables
# ============================================================================
# Copy to .env and fill in all values before running docker compose up.
# Required variables are marked; optional ones have defaults shown.

# --- Server ---
NODE_ENV=production
PORT=8080
# Comma-separated list of allowed origins for CORS
CORS_ORIGIN=http://localhost:3000

# --- Security (REQUIRED — at least 32 characters each) ---
# Generate with: openssl rand -hex 32
JWT_SECRET=
ENCRYPTION_KEY=

# --- Supabase (REQUIRED) ---
# Cloud: https://your-project.supabase.co
# Self-hosted: set by docker-compose.selfhosted.yml override
SUPABASE_PROJECT_URL=
SUPABASE_PUBLISHABLE_API_KEY=sb_publishable_
SUPABASE_SECRET_KEY=sb_secret_

# --- OpenRouter AI (REQUIRED) ---
OPENROUTER_API_KEY=sk-or-v1-
OPENROUTER_MODEL_SMALL=google/gemini-3-flash-preview
OPENROUTER_MODEL_LARGE=google/gemini-3-pro-preview

# --- Self-hosted Supabase only (used by docker-compose.selfhosted.yml) ---
# POSTGRES_PASSWORD=
# POSTGRES_PORT=5432

# --- Optional ---
LOG_LEVEL=info
# APP_URL=https://audit.example.com
